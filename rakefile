        <w:qFormat/>
        <w:pPr>
          <w:jc w:val="center"/>
          <w:spacing w:before="1440" w:after="0"/>
        </w:pPr>
        <w:rPr>
          <w:rFonts w:ascii="Garamond" w:hAnsi="Garamond" w:eastAsia="Garamond" w:cs="Garamond"/>
          <w:b/>
          <w:bCs/>
          <w:color w:val="000000"/>
          <w:sz w:val="22"/>
          <w:szCs w:val="22"/>
        </w:rPr>
      </w:style>
    </w:styles>
  XML
end

def create_default_reference_docx(path, overwrite = false)
  return if File.exist?(path) && !overwrite

  Dir.mktmpdir("reference_docx") do |dir|
    FileUtils.mkdir_p(File.join(dir, "_rels"))
    FileUtils.mkdir_p(File.join(dir, "word", "_rels"))
    File.write(File.join(dir, "[Content_Types].xml"), default_reference_content_types_xml)
    File.write(File.join(dir, "_rels", ".rels"), default_reference_root_rels_xml)
    File.write(File.join(dir, "word", "document.xml"), default_reference_document_xml)
    File.write(File.join(dir, "word", "styles.xml"), default_reference_styles_xml)
    File.write(File.join(dir, "word", "settings.xml"), default_reference_settings_xml)
    File.write(File.join(dir, "word", "_rels", "document.xml.rels"), default_reference_document_rels_xml)

    absolute_path = File.expand_path(path)
    FileUtils.rm_f(absolute_path)
    Dir.chdir(dir) do
      unless system("zip", "-q", "-r", absolute_path, ".")
        warn "*** WARNING: could not create #{path}; zip command failed"
      end
    end
  end
end

desc "create a new .rakefile.yaml"
task :init do
  yaml_file = ".rakefile.yaml"
  if FileTest.exist?(yaml_file)
    puts "*** #{yaml_file} already exists; just edit it"
  end
  File.open(yaml_file, "w") do |file|
    file.write(<<-STRING
---
:target_files:
  - ./story.txt
:title: "title goes here"
:author: "author goes here"
:target_words: 125000
:date_start: '#{Date.today}'
:chapter_head_tag: '** chapter'
:frontmatter: []
:docx_reference: .default.docx
:size_cuttoff_chapter: 600
:size_cutoff_force_done: 'AAA-chapter-complete'
# use the tag below to force a chapter to be marked incomplete even if it exceeds the cutoff
# :size_cutoff_force_incomplete: 'TAG_NAME'
STRING
              )
  end
  create_default_reference_docx(".default.docx", true)
  puts "created file ./#{yaml_file}"
  puts "created file ./.default.docx"
end

desc "create or overwrite the default DOCX reference file"
task :init_docx do
  create_default_reference_docx(".default.docx", true)
  puts "created file ./.default.docx"
end


# takes an optional git hash in case you've already committed the files and still want to run the command
#
# without git hash spec:
#   rake
#
# with git hash spec:
#   rake default[047b60168aa7ee1ba2d1d9cd515ddf749ccee8f3]
#
def normalize_act_id(act_id)
  return nil if act_id.nil?

  act_id.to_s.strip.sub(/\AAct\s+/i, "").split(":", 2).first.strip.upcase
end

def act_id_from_line(line)
  normalize_act_id(line[/^\*\s*Act\s*([^:]+)/i, 1])
end

def normalize_act_filter(act_filter)
  return :all if act_filter == :all || act_filter.nil?

  Array(act_filter).map { |act_id| normalize_act_id(act_id) }.compact.to_set
end

def act_selected?(act_id, normalized_filter)
  return true if normalized_filter == :all

  normalized_filter.include?(normalize_act_id(act_id))
end

def chapter_act_id(chapter_num, acts)
  return nil if acts.empty?

  sorted_acts = acts.sort_by { |act| act[:before_chapter] || 0 }
  current_act = sorted_acts.select { |act| act[:before_chapter] && chapter_num >= act[:before_chapter] }.last
  current_act ||= sorted_acts.first
  act_id_from_line(current_act[:line])
end

def collect_default_chapters(config, act_filter)
  normalized_filter = normalize_act_filter(act_filter)
  chapters = []
  all_data = {}
  all_act_ids = []

  $target_files.each do |file|
    data = parse_chapters_and_acts_from_file(file, config)
    all_data[file] = data

    data[:acts].each do |act|
      act_id = act_id_from_line(act[:line])
      all_act_ids << act_id if act_id && !all_act_ids.include?(act_id)
    end

    data[:chapters].each do |chap_num, chapter_data|
      act_id = chapter_act_id(chap_num, data[:acts])
      next unless act_selected?(act_id, normalized_filter)

      chapters << {
        :file => file,
        :chapter_num => chap_num,
        :act_id => act_id,
        :text => chapter_data[:full_text]
      }
    end
  end

  { :chapters => chapters, :all_data => all_data, :all_act_ids => all_act_ids }
end

def default_chapter_done?(text, config)
  force_done_tag = config[:size_cutoff_force_done] || config[:size_cuttoff_ignore_tag]
  force_done = force_done_tag && text.match?(force_done_tag)
  force_incomplete = config[:size_cutoff_force_incomplete] && text.match?(config[:size_cutoff_force_incomplete])

  if force_incomplete
    false
  elsif force_done
    true
  else
    text.split.size > $size_cutoff_chapter
  end
end

def structural_default_line?(line, chapter_head_tag)
  line.match?(/^\*\s*Act\s+/i) || line.match?(/^#{Regexp.escape(chapter_head_tag)}\s/i)
end

def diff_command_for_file(git_hash, file)
  if git_hash && git_hash.to_s.strip != ""
    "git diff -U999999 #{git_hash} -- #{file}"
  else
    "git diff -U999999 -- #{file}"
  end
end

def diff_words_by_act(config, git_hash)
  chapter_head_tag = config[:chapter_head_tag] || "== chapter"
  by_act = Hash.new { |h, k| h[k] = { :plus => 0, :minus => 0 } }

  $target_files.each do |file|
    current_act_id = nil
    pending_plus = 0
    pending_minus = 0

    `#{diff_command_for_file(git_hash, file)}`.lines.each do |line|
      next if line.start_with?("diff --git ", "index ", "--- ", "+++ ", "@@")
      next if line.start_with?("\\ No newline")

      prefix = line[0]
      next unless [" ", "+", "-"].include?(prefix)

      content = line[1..-1].to_s.chomp

      if content.match?(/^\*\s*Act\s+/i)
        current_act_id = act_id_from_line(content)
        if current_act_id
          by_act[current_act_id][:plus] += pending_plus
          by_act[current_act_id][:minus] += pending_minus
        end
        pending_plus = 0
        pending_minus = 0
        next
      end

      next if structural_default_line?(content, chapter_head_tag)
      next unless prefix == "+" || prefix == "-"

      word_count = content.split.size
      if current_act_id
        if prefix == "+"
          by_act[current_act_id][:plus] += word_count
        else
          by_act[current_act_id][:minus] += word_count
        end
      elsif prefix == "+"
        pending_plus += word_count
      else
        pending_minus += word_count
      end
    end
  end

  by_act
end

def diff_word_totals_for_filter(config, git_hash, act_filter)
  normalized_filter = normalize_act_filter(act_filter)
  by_act = diff_words_by_act(config, git_hash)
  selected = by_act.select { |act_id, _counts| act_selected?(act_id, normalized_filter) }
  words_plus = selected.values.sum { |counts| counts[:plus] }
  words_minus = selected.values.sum { |counts| counts[:minus] }

  { :plus => words_plus, :minus => words_minus, :by_act => selected }
end

def diff_word_count_for_file(git_hash, file)
  plus = 0
  minus = 0

  `#{diff_command_for_file(git_hash, file)}`.lines.each do |line|
    next if line.start_with?("diff --git ", "index ", "--- ", "+++ ", "@@")

    if line.start_with?("+")
      plus += line[1..-1].to_s.split.size
    elsif line.start_with?("-")
      minus += line[1..-1].to_s.split.size
    end
  end

  { :plus => plus, :minus => minus }
end

def marker_count_summary(text, marker)
  text.scan(/\b#{Regexp.escape(marker)}\b/).size
end

def print_default_summary(label, config, target_words, stats)
  percent_words = stats[:percent_words]
  percent_chapters = stats[:percent_chapters]
  expansion_words = stats[:expansion_words]
  words_delta = stats[:words_plus] - stats[:words_minus]

  puts ""
  puts "  +--------------------"
  puts "  | #{label}"
  puts "  |"
  puts "  | story :    #{stats[:actual_words].commify} / #{target_words&.commify}  words ( #{sprintf('%0.2f', percent_words * 100)} % )"
  puts "  |            #{stats[:actual_words] / $words_per_page} / #{target_words / $words_per_page}  pages"
  puts "  |            #{stats[:actual_chapters]} / #{stats[:target_chapters]} chapters ( #{sprintf('%0.2f', percent_chapters * 100)} % )"
  puts "  | "
  puts "  |            expansion ratio: #{sprintf('%2.2f', stats[:expansion_ratio])}"
  puts "  |            words at this ratio: #{expansion_words.commify}"
  puts "  |            pages at this ratio: #{(expansion_words / $words_per_page).commify}"
  puts "  |"
  puts "  |            #{stats[:actual_words].commify} / #{expansion_words.commify} words at this ratio ( #{sprintf('%0.2f', stats[:expansion_progress] * 100)} % )"
  puts "  |            #{(stats[:actual_words] / $words_per_page).commify} / #{(expansion_words / $words_per_page).commify} pages at this ratio"
  puts "  | "

  if stats[:revised_words] > 0
    puts "  | revision:"
    puts "  |   revised:           #{stats[:revised_words].commify} / #{stats[:actual_words].commify} words ( #{sprintf('%0.2f', stats[:revised_fraction] * 100)} % )"
    puts "  | "
  end

  [:XXX, :YYY, :ZZZ].each do |marker|
    count = stats[:marker_counts][marker]
    puts "  | #{marker.to_s.downcase}:                #{count}" if count > 0
  end

  if stats[:show_unused_delta]
    puts "  | moved to unused:    #{stats[:unused_delta] > 0 ? "+" : ""}#{stats[:unused_delta].commify}"
    puts "  | "
  end

  puts "  | today's word delta: #{words_delta > 0 ? "+" : ""}#{words_delta.commify}   (+#{stats[:words_plus].commify} -#{stats[:words_minus].commify})"

  if stats[:diff_by_act].size > 1
    puts "  | act deltas:"
    stats[:diff_by_act].keys.sort.each do |act_id|
      counts = stats[:diff_by_act][act_id]
      delta = counts[:plus] - counts[:minus]
      next if delta == 0 && counts[:plus] == 0 && counts[:minus] == 0

      puts "  |   #{act_id}: #{delta > 0 ? "+" : ""}#{delta.commify}   (+#{counts[:plus].commify} -#{counts[:minus].commify})"
    end
  end

  puts "  | days since start:   #{stats[:days_since_start]}"
  puts "  | average rate:       #{stats[:write_rate].commify} words / day"
  puts "  | to go:              #{stats[:to_go_words].commify} words ;  #{stats[:to_go_days].commify} days ( #{(Date.today + stats[:to_go_days]).strftime('%d %b %Y')} )"
  puts "  | to go (expansion):  #{stats[:to_go_words_expansion].commify} words ;  #{stats[:to_go_days_expansion].commify} days ( #{(Date.today + stats[:to_go_days_expansion]).strftime('%d %b %Y')} )"
  puts "  +--------------------"
  puts ""
end

def validate_book_split_acts!(book_to_acts, all_act_ids)
  act_to_books = Hash.new { |h, k| h[k] = [] }
  book_to_acts.each do |book, acts|
    acts.each { |act| act_to_books[normalize_act_id(act)] << book }
  end

  missing_acts = all_act_ids.map { |act| normalize_act_id(act) }.uniq - act_to_books.keys
  unless missing_acts.empty?
    abort "*** ERROR: The following acts are not assigned to any book in book_split: #{missing_acts.join(', ')}"
  end

  multi_books = act_to_books.select { |_act, books| books.size > 1 }
  unless multi_books.empty?
    msg = multi_books.map { |act, books| "Act '#{act}' assigned to multiple books: #{books.join(', ')}" }.join("\n  ")
    abort "*** ERROR: The following acts are assigned to multiple books in book_split:\n  #{msg}"
  end
end

def default_internal(config, args, unused_file, target_words, act_filter = :all, label = nil, allow_book_split = true)
  book_split = config[:book_split] || config["book_split"]
  if allow_book_split && act_filter == :all && book_split
    collected = collect_default_chapters(config, :all)
    book_to_acts = book_split.transform_keys(&:to_s).transform_values do |acts|
      acts.map { |act| normalize_act_id(act) }
    end

    validate_book_split_acts!(book_to_acts, collected[:all_act_ids])

    selected_books = if ENV["BOOK"]
      [ENV["BOOK"].to_s]
    else
      book_to_acts.keys
    end

    selected_books.each do |book|
      abort "*** ERROR: Unknown book '#{book}' in BOOK" unless book_to_acts.key?(book)

      default_internal(config, args, unused_file, target_words, book_to_acts[book], book, false)
    end
    return
  end

  collected = collect_default_chapters(config, act_filter)
  chapters = collected[:chapters]
  abort "No chapters found in selected acts" if chapters.empty?

  text = chapters.map { |chapter| chapter[:text] }.join("\n")
  actual_words = text.split.size
  target_chapters = chapters.size
  actual_chapters = chapters.count { |chapter| default_chapter_done?(chapter[:text], config) }
  percent_words = (target_words && target_words > 0) ? (actual_words * 1.0 / target_words) : 0.0
  percent_chapters = target_chapters > 0 ? (actual_chapters * 1.0 / target_chapters) : 0.0
  expansion_ratio = percent_chapters > 0 ? (percent_words / percent_chapters) : 0.0
  expansion_words = percent_chapters > 0 ? (target_words * expansion_ratio).floor : 0
  expansion_progress = expansion_words > 0 ? (actual_words * 1.0 / expansion_words) : 0.0

  date_start = Date.parse(config[:date_start].to_s) rescue Date.today
  days_since_start = [(Date.today - date_start).to_i, 1].max
  write_rate = [actual_words / days_since_start, 1].max
  to_go_words = [target_words - actual_words, 0].max
  to_go_days = to_go_words / write_rate
  to_go_words_expansion = [expansion_words - actual_words, 0].max
  to_go_days_expansion = to_go_words_expansion / write_rate

  revised_words = text.split(/\s+/).index { |word| word.match?(/^<--+/) } || 0
  revised_fraction = actual_words > 0 ? (revised_words * 1.0 / actual_words) : 0.0

  diff_counts = diff_word_totals_for_filter(config, args[:git_hash], act_filter)
  unused_delta = 0
  show_unused_delta = act_filter == :all
  if show_unused_delta && File.exist?(unused_file)
    unused_counts = diff_word_count_for_file(args[:git_hash], unused_file)
    unused_delta = unused_counts[:plus] - unused_counts[:minus]
  end

  marker_counts = {
    :XXX => marker_count_summary(text, "XXX"),
    :YYY => marker_count_summary(text, "YYY"),
    :ZZZ => marker_count_summary(text, "ZZZ")
  }

  stats = {
    :actual_words => actual_words,
    :actual_chapters => actual_chapters,
    :target_chapters => target_chapters,
    :percent_words => percent_words,
    :percent_chapters => percent_chapters,
    :expansion_ratio => expansion_ratio,
    :expansion_words => expansion_words,
    :expansion_progress => expansion_progress,
    :revised_words => revised_words,
    :revised_fraction => revised_fraction,
    :marker_counts => marker_counts,
    :unused_delta => unused_delta,
    :show_unused_delta => show_unused_delta,
    :words_plus => diff_counts[:plus],
    :words_minus => diff_counts[:minus],
    :diff_by_act => diff_counts[:by_act],
    :days_since_start => days_since_start,
    :write_rate => write_rate,
    :to_go_words => to_go_words,
    :to_go_days => to_go_days,
    :to_go_words_expansion => to_go_words_expansion,
    :to_go_days_expansion => to_go_days_expansion
  }

  print_default_summary(label || config[:title] || $title, config, target_words, stats)
end

desc "generate stats - optionally from a git hash with `rake default[<hashID>]`"
task :default, [:git_hash] do |t, args|
  default_internal(config, args, unused_file, target_words)
end

# Helper: build stats used by other tasks (commit message generation)
def build_basic_stats(git_hash = nil)
  cat_str = get_target_content($target_files, git_hash)
  actual_words = cat_str.split.size
  # use global $target_words (guard for nil/0)
  percent_words = ($target_words && $target_words > 0) ? (actual_words * 1.0 / $target_words) : 0.0
  { :actual_words => actual_words, :percent_words => percent_words }
end

WORD_GRAPH_CACHE_VERSION = 1

def git_file_content_at_commit(git_hash, file)
  [file, file.sub(%r{\A\./+}, "")].uniq.each do |path|
    git_ref = "#{git_hash}:#{path}"
    next unless system("git", "cat-file", "-e", git_ref, out: File::NULL, err: File::NULL)

    return `git show #{Shellwords.escape(git_ref)}`
  end

  ""
end

def target_files_from_config(config_hash)
  if config_hash[:target_files] || config_hash["target_files"]
    config_hash[:target_files] || config_hash["target_files"]
  elsif config_hash[:target_file] || config_hash["target_file"]
    [config_hash[:target_file] || config_hash["target_file"]]
  else
    ["story.txt"]
  end
end

def config_at_commit(git_hash, fallback_config)
  contents = git_file_content_at_commit(git_hash, ".rakefile.yaml")
  return fallback_config if contents.strip == ""

  YAML.load(contents) || fallback_config
rescue
  fallback_config
end

def target_content_at_commit(git_hash, target_files)
  target_files.map { |file| git_file_content_at_commit(git_hash, file) }.join
end

def fresh_word_graph_cache
  {
    "version" => WORD_GRAPH_CACHE_VERSION,
    "commits" => {}
  }
end

def word_graph_cache_path
  path = `git rev-parse --git-path word_graph_cache.yml 2>/dev/null`.strip
  path.empty? ? ".word_graph_cache.yml" : path
end

def load_word_graph_cache
  path = word_graph_cache_path
  return fresh_word_graph_cache unless File.exist?(path)

  cache = YAML.load_file(path) || {}
  return fresh_word_graph_cache unless cache["version"] == WORD_GRAPH_CACHE_VERSION
  return fresh_word_graph_cache unless cache["commits"].is_a?(Hash)

  cache
rescue
  fresh_word_graph_cache
end

def save_word_graph_cache(cache)
  path = word_graph_cache_path
  FileUtils.mkdir_p(File.dirname(path))
  temp_path = "#{path}.tmp.#{$$}"
  File.write(temp_path, cache.to_yaml)
  File.rename(temp_path, path)
rescue => e
  warn "WARNING: could not write word_graph cache at #{path}: #{e.message}"
ensure
  File.delete(temp_path) if temp_path && File.exist?(temp_path)
end

def word_count_at_commit(git_hash, config, cache)
  cached = cache["commits"][git_hash]
  return cached["words"] if cached.is_a?(Hash) && cached.key?("words")

  commit_config = config_at_commit(git_hash, config)
  target_files = target_files_from_config(commit_config)
  words = target_content_at_commit(git_hash, target_files).split.size
  cache["commits"][git_hash] = { "words" => words }
  words
end

def word_graph_start_date(config)
  Date.parse(config[:date_start].to_s).to_s
rescue
  nil
end

def word_history_points(config)
  history = []
  cache = load_word_graph_cache
  start_date = word_graph_start_date(config)
  since_arg = start_date ? "--since=#{start_date} 00:00:00" : nil
  git_log_args = ["git", "log", "--reverse", "--date=short", "--format=%H%x09%ad"]
  git_log_args << since_arg if since_arg
  lines = `#{git_log_args.map { |arg| Shellwords.escape(arg) }.join(' ')}`
  lines.each_line do |line|
    hash, date = line.chomp.split("\t", 2)
    next unless hash && date

    history << [date, word_count_at_commit(hash, config, cache)]
  end

  save_word_graph_cache(cache)

  points = history.each_with_object({}) do |(date, words), by_date|
    by_date[date] = words
  end.map { |date, words| [date, words] }.sort_by(&:first)

  if start_date && !points.empty? && points.first.first != start_date
    points.unshift([start_date, 0])
  end

  points
end

def sample_points(points, width)
  return points if points.size <= width

  (0...width).map do |idx|
    source_idx = (idx * (points.size - 1).to_f / (width - 1)).round
    points[source_idx]
  end
end

def render_word_graph(points, width = 60, height = 12)
  return ["No git history found for target files."] if points.empty?

  sampled = sample_points(points, width)
  words = sampled.map(&:last)
  min_words = words.min
  max_words = words.max
  span = [max_words - min_words, 1].max
  grid = Array.new(height) { Array.new(sampled.size, " ") }

  sampled.each_with_index do |(_date, word_count), idx|
    row = height - 1 - ((word_count - min_words) * (height - 1) / span.to_f).round
    grid[row][idx] = "*"
  end

  lines = grid.each_with_index.map do |row, idx|
    label_value = max_words - (idx * span / [height - 1, 1].max.to_f).round
    "#{sprintf('%7s', label_value.commify)} | #{row.join}"
  end

  lines << "        +#{"-" * (sampled.size + 1)}"
  lines << "         #{sampled.first.first}#{sampled.size > 12 ? ' ' * [sampled.size - 20, 1].max : '  '}#{sampled.last.first}"
  lines
end

def print_word_graph(points)
  abort "No git history found for target files" if points.empty?

  puts ""
  puts "  +--------------------"
  puts "  | #{$title} word history"
  puts "  |"
  render_word_graph(points).each { |line| puts "  | #{line}" }
  first_date, first_words = points.first
  last_date, last_words = points.last
  days = [(Date.parse(last_date) - Date.parse(first_date)).to_i, 1].max
  delta = last_words - first_words
  puts "  |"
  puts "  | #{first_date}: #{first_words.commify} words"
  puts "  | #{last_date}: #{last_words.commify} words"
  puts "  | net: #{delta >= 0 ? '+' : ''}#{delta.commify} words"
  puts "  | avg: #{(delta / days).commify} words/day"
  puts "  +--------------------"
  puts ""
end

desc "Show ASCII graph of total words over git history"
task :word_graph do
  print_word_graph(word_history_points(config))
end

# Build commit message reusing the same formatting as the default output
def make_commit_message(git_hash = nil)
  stats = build_basic_stats(git_hash)
  actual_words = stats[:actual_words]
  percent_words = stats[:percent_words]
  "#{$title} : #{actual_words.commify} / #{$target_words&.commify} words ( #{sprintf('%0.2f', percent_words * 100)} % )"
end

desc "git add . && git commit -m <message> -- message uses same X / Y words (Z%) logic"
task :git do
  msg = make_commit_message
  puts "Committing with message: #{msg}"
  system("git", "add", ".")

  # only commit if there are changes to commit
  changed = `git status --porcelain`
  if changed.strip == ""
    puts "No changes to commit."
  else
    system("git", "commit", "-m", msg)
  end
end


desc "change most recent commit's date to the supplied date (5pm ET). Usage: rake git_change_date['Feb 2 2026']"
task :git_change_date, [:date_str] do |t, args|
  if !args[:date_str] || args[:date_str].strip == ""
    abort "Usage: rake git_change_date['<date string>']"
  end

  begin
    parsed = Date.parse(args[:date_str])
  rescue => e
    abort "Error parsing date: #{e}"
  end

  # set time to 5pm Eastern Time (offset -05:00). If DST handling is required,
  # consider using the 'tzinfo' gem to compute the correct offset for the date.
  ts = Time.new(parsed.year, parsed.month, parsed.day, 17, 0, 0, "-05:00")
  date_arg = ts.strftime("%Y-%m-%d %H:%M:%S %z")

  puts "Amending most recent commit with date: #{date_arg}"

  unless system("git", "commit", "--amend", "--date", date_arg, "--no-edit")
    abort "git commit --amend --date failed"
  end

  env = { "GIT_COMMITTER_DATE" => date_arg }
  unless system(env, "git", "commit", "--amend", "--no-edit")
    abort "GIT_COMMITTER_DATE git commit --amend failed"
  end
end


desc "alias for :chapters"
task :ch, [:git_hash] do |t, args|
  Rake::Task[:chapters].invoke(args.values)
end

desc "show verbose chapter stats, hiding completed chapters"
task :chv, [:git_hash] do |t, args|
  ret = get_chapter_hash(config, args[:git_hash])
  print_chapter_report(title, config, ret, $target_files, nil, false, true)
end

desc "generate verbose stats about chapters"
task :chapters, [:git_hash] do |t, args|
  ret           = get_chapter_hash(config, args[:git_hash])
  print_chapter_report(title, config, ret)
end

task :clean do |t|
  `rm -f  '##{$target_file}#' '##{$target_file}' 2> /dev/null`
  `rm -f output.txt output.html output.docx *~ .\#* \#* 2> /dev/null`
  
  # do the globbing manually to avoid interactions between Ruby `...` and shell stuff
  # that was causing globbing not to work
  
  system("rm", "-f", *Dir.glob("#*#"))  
end

task :outlines do |t|
  subdir = "./notes/outlines/"
  [
    "06c_outline_wyatt.txt" ,
    "13_domestic.txt" ].each do |f|
    infile_name = "#{subdir}#{f}"

    puts "========== #{infile_name}"
    count = 0
    first = true
    File.open(infile_name, "r") do |infile_h|
      
      while (line = infile_h.gets)
        if line.match(/^\*\* /)
          if first
            first = false
          else
            puts "scene = #{count}"
            count = 0
          end
          puts  line
        elsif line.match(/^\s*scene/)
          count += 1
        end
      end
    end
    puts "scene = #{count}"
  end
end

# regression tests for the tool
task :self_test do |t|
  Dir.chdir("test") do
    open("story.txt", "w") { |f| f << <<~ENDSTRING
             ** chapter 1: one
             foo bar baz
             ** chapter 2: two
             foo bar baz foo bar baz
             ** chapter 3: thre
             foo bar baz foo bar baz baz baz baz
             ENDSTRING
    }
    `ln -f -s ../rakefile .`
    `rake init`
	`cp story.txt story.txt_ORIG`
    `rake > output.txt`
    actual = `grep "today's word delta" output.txt`.gsub!(/\n/, "")
    gold = "  | today's word delta: +13   (+15 -2)"
    puts "actual = .#{actual}."
    puts "gold   = .#{gold}."

    if actual == gold
      puts "self-test passed"
    else
      raise "self-test failed"
    end
    `rm ./.rakefile.yaml ./story.txt ./output.txt ./rakefile`
  end
end
# Helper: parse chapters and Act lines from a single file
# Returns hash with :chapters and :acts
# chapters: { chapter_num => { :title, :full_text, :source_file, :pragmas } }
# acts: ordered array of { :line => "* Act ...", :before_chapter => chapter_num_or_nil }
def parse_chapters_and_acts_from_file(file_path, config)
  if !File.exist?(file_path)
    warn "*** warning: file #{file_path} not found"
    return { :chapters => {}, :acts => [] }
  end
  
  contents = File.read(file_path)
  parse_chapters_and_acts_from_contents(contents, file_path, config)
end

def target_file_clean_in_git?(file)
  system("git", "ls-files", "--error-unmatch", file, out: File::NULL, err: File::NULL) &&
    system("git", "diff", "--quiet", "--", file) &&
    system("git", "diff", "--cached", "--quiet", "--", file)
end

def renumber_chapters_in_contents(contents, config)
  chapter_head_tag = config[:chapter_head_tag] || "== chapter"
  next_act_start = 1
  next_chapter_num = nil

  contents.lines.map do |line|
    if line.match?(/^\* Act\b/i)
      next_chapter_num = next_act_start
      next_act_start += next_act_start == 1 ? 9 : 10
      line
    elsif line =~ /^(\s*#{Regexp.escape(chapter_head_tag)}\s+)(\d+)/
      next_chapter_num ||= 1
      new_line = line.sub(/^(\s*#{Regexp.escape(chapter_head_tag)}\s+)\d+/, "\\1#{next_chapter_num}")
      next_chapter_num += 1
      next_act_start += 10 while next_act_start <= next_chapter_num
      new_line
    else
      line
    end
  end.join
end

def renumber_chapters_in_file(file, config)
  original = File.read(file)
  updated = renumber_chapters_in_contents(original, config)
  File.write(file, updated) if updated != original
  updated != original
end

desc "Renumber chapters in each source file by act"
task :renumber do
  dirty_files = $target_files.reject { |file| target_file_clean_in_git?(file) }
  unless dirty_files.empty?
    abort "*** ERROR: refusing to renumber because these source files are not clean in git: #{dirty_files.join(', ')}"
  end

  $target_files.each do |file|
    abort "*** ERROR: target file #{file} not found" unless File.exist?(file)

    changed = renumber_chapters_in_file(file, config)
    puts "#{changed ? 'Renumbered' : 'Already numbered'} #{file}"
  end
end

def parse_chapters_and_acts_from_contents(contents, file_path, config)
  chapter_head_tag = config[:chapter_head_tag] || "== chapter"
  lines = contents.split("\n")
  
  acts = []
  chapters = {}
  current_chapter_num = nil
  last_act_before_chapter = nil
  last_act_before_chapter_lineno = nil
  
  # First pass: extract Act lines and track which chapter comes after
  lines.each_with_index do |line, idx|
    lineno = idx + 1
    if line =~ /^\* /
      # Line starts with single asterisk
      if line !~ /^\* Act /
        bytes = line.bytes.map { |b| sprintf("%02x", b) }.join(' ')
        if line =~ /chapter/i
          abort "*** SYNTAX ERROR in #{file_path}: Line #{lineno}: starts with '*' but not followed by 'Act': #{line.inspect}\n  bytes: #{bytes}\n  Hint: did you forget an extra asterisk for the chapter?"
        else
          abort "*** SYNTAX ERROR in #{file_path}: Line #{lineno}: starts with '*' but not followed by 'Act': #{line.inspect}\n  bytes: #{bytes}"
        end
      end
      # Valid Act line - will be associated with the next chapter we see
      last_act_before_chapter = line
      last_act_before_chapter_lineno = lineno
    elsif line =~ /^#{Regexp.escape(chapter_head_tag)}\s/
      # Extract chapter number
      line.match(/ (\d+)/)
      if $1
        current_chapter_num = $1.to_i
        # If we have an act waiting, associate it with this chapter
        if last_act_before_chapter
          acts << { :line => last_act_before_chapter, :before_chapter => current_chapter_num, :line_no => last_act_before_chapter_lineno }
          last_act_before_chapter = nil
          last_act_before_chapter_lineno = nil
        end
      end
    end
  end
  
  # Second pass: parse chapters (excluding Act lines from content)
  arr = contents.split(chapter_head_tag)
  arr = arr.slice(1..9999)
  arr ||= []
  
  arr.each do |text|
    lines = text.split("\n")
    title_line = lines[0]
    
    # Extract chapter number
    title_line.match(/ (\d+)/)
    chapter_num_str = $1
    
    next unless chapter_num_str
    
    chap_num = chapter_num_str.to_i
    
    # Remove Act lines from chapter content
    content_lines = lines.reject { |l| l =~ /^\* Act / }
    clean_text = content_lines.join("\n")
    
    # Reconstruct chapter text
    full_text = "#{chapter_head_tag}#{clean_text}"
    
    # Parse pragmas from chapter text
    pragmas = parse_pragmas_from_chapter_text(full_text)
    
    chapters[chap_num] = {
      :title => title_line,
      :full_text => full_text,
      :source_file => file_path,
      :pragmas => pragmas
    }
  end
  
  { :chapters => chapters, :acts => acts }
end

# Helper to extract source identifier from filename (e.g., "lopez" from "story_lopez.txt")
def extract_source_id(filename)
  # Remove leading path, extract part after last underscore and before extension
  basename = File.basename(filename)
  if basename =~ /^.*?_(.+?)\.\w+$/
    $1.upcase
  else
    basename.upcase
  end
end

# Parse pragmas from chapter text
# Returns hash with :defines (string or nil), :depends_on (array of strings), and :must_come_before (array of strings)
def parse_pragmas_from_chapter_text(chapter_text)
  defines = nil
  depends_on = []
  must_come_before = []
  
  chapter_text.each_line do |line|
    # Look for DEFINE-TAG pragma
    if line =~ /^\s*#\s*DEFINE-TAG:\s*(\S+)/
      defines = $1
    end
    
    # Look for MUST-BE-AFTER pragma(s) - can have multiple occurrences
    if line =~ /^\s*#\s*MUST-BE-AFTER:\s*(.+)/
      deps_str = $1
      # Split by comma, strip whitespace from each
      deps_str.split(',').each do |dep|
        dep_tag = dep.strip
        depends_on << dep_tag if dep_tag != ""
      end
    end
    
    # Look for MUST-BE-BEFORE pragma(s) - can have multiple occurrences
    if line =~ /^\s*#\s*MUST-BE-BEFORE:\s*(.+)/
      before_str = $1
      # Split by comma, strip whitespace from each
      before_str.split(',').each do |tag|
        tag_name = tag.strip
        must_come_before << tag_name if tag_name != ""
      end
    end
  end
  
  { :defines => defines, :depends_on => depends_on, :must_come_before => must_come_before }
end

# Build global pragma registry from all files
# Returns hash with validation status and mappings
def build_pragma_registry(all_data, all_files)
  tag_definitions = {}        # tag_name => "file:chapter_num"
  chapter_dependencies = {}   # "file:chapter_num" => [tag1, tag2, ...] (MUST-BE-AFTER)
  chapter_must_come_before = {} # "file:chapter_num" => [tag1, tag2, ...] (MUST-BE-BEFORE)
  undefined_tags = Set.new
  unused_tags = Set.new
  circular_deps = []
  
  # First pass: collect all DEFINE-TAG pragmas
  all_files.each do |file|
    next unless all_data[file]
    
    all_data[file][:chapters].each do |local_ch_num, chapter_data|
      pragmas = chapter_data[:pragmas] || { :defines => nil, :depends_on => [] }
      
      if pragmas[:defines]
        tag_name = pragmas[:defines]
        chapter_id = "#{file}:#{local_ch_num}"
        
        if tag_definitions[tag_name]
          # Tag redefined - warn or error
          abort "*** ERROR: Tag '#{tag_name}' defined multiple times: in #{tag_definitions[tag_name]} and #{chapter_id}"
        end
        
        tag_definitions[tag_name] = chapter_id
        unused_tags.add(tag_name)  # Start with all tags as unused; we'll mark them used below
      end
    end
  end
  
  # Second pass: collect all MUST-BE-AFTER and MUST-BE-BEFORE dependencies and mark tags as used
  all_files.each do |file|
    next unless all_data[file]
    
    all_data[file][:chapters].each do |local_ch_num, chapter_data|
      pragmas = chapter_data[:pragmas] || { :defines => nil, :depends_on => [], :must_come_before => [] }
      
      chapter_id = "#{file}:#{local_ch_num}"
      
      # Handle MUST-BE-AFTER dependencies
      if pragmas[:depends_on].size > 0
        chapter_dependencies[chapter_id] = pragmas[:depends_on].dup
        
        # Check for undefined tags and mark defined tags as used
        pragmas[:depends_on].each do |tag|
          if tag_definitions[tag]
            unused_tags.delete(tag)
          else
            undefined_tags.add(tag)
          end
        end
      end
      
      # Handle MUST-BE-BEFORE dependencies
      if pragmas[:must_come_before].size > 0
        chapter_must_come_before[chapter_id] = pragmas[:must_come_before].dup
        
        # Check for undefined tags and mark defined tags as used
        pragmas[:must_come_before].each do |tag|
          if tag_definitions[tag]
            unused_tags.delete(tag)
          else
            undefined_tags.add(tag)
          end
        end
      end
    end
  end
  
  # Detect circular dependencies using DFS
  visited = Set.new
  rec_stack = Set.new
  
  def has_cycle_dfs(chapter_id, graph, visited, rec_stack, tag_definitions)
    visited.add(chapter_id)
    rec_stack.add(chapter_id)
    
    deps = graph[chapter_id] || []
    deps.each do |tag|
      dep_chapter_id = tag_definitions[tag]
      next unless dep_chapter_id  # Skip undefined tags (already recorded)
      
      if !visited.include?(dep_chapter_id)
        if has_cycle_dfs(dep_chapter_id, graph, visited, rec_stack, tag_definitions)
          return true
        end
      elsif rec_stack.include?(dep_chapter_id)
        # Found a cycle
        return true
      end
    end
    
    rec_stack.delete(chapter_id)
    false
  end
  
  chapter_dependencies.keys.each do |chapter_id|
    if !visited.include?(chapter_id)
      if has_cycle_dfs(chapter_id, chapter_dependencies, visited, rec_stack, tag_definitions)
        circular_deps << chapter_id
      end
    end
  end
  
  {
    :tag_definitions => tag_definitions,
    :chapter_dependencies => chapter_dependencies,
    :chapter_must_come_before => chapter_must_come_before,
    :undefined_tags => undefined_tags.to_a,
    :unused_tags => unused_tags.to_a,
    :circular_deps => circular_deps
  }
end

# Perform topological sort on chapters respecting pragma dependencies
# Returns ordered array of chapter IDs ("file:local_ch_num")
def topological_sort_chapters(chapter_dependencies, chapter_must_come_before, tag_definitions, all_chapters_by_id, source_order_sequences = [], chapter_act_order = {})
  # Build in-degree map and adjacency list for topological sort
  in_degree = {}
  adjacency = {}
  
  all_chapters_by_id.each do |chapter_id|
    in_degree[chapter_id] = 0
    adjacency[chapter_id] = []
  end

  add_topological_edge = lambda do |before_id, after_id|
    next unless in_degree.key?(before_id) && in_degree.key?(after_id)
    adjacency[before_id] ||= []
    next if adjacency[before_id].include?(after_id)

    adjacency[before_id] << after_id
    in_degree[after_id] = (in_degree[after_id] || 0) + 1
  end
  
  # Handle MUST-BE-AFTER dependencies (this chapter depends on tagged chapters)
  chapter_dependencies.each do |chapter_id, dep_tags|
    dep_tags.each do |tag|
      dep_chapter_id = tag_definitions[tag]
      next unless dep_chapter_id
      
      # dep_chapter_id must come before chapter_id
      add_topological_edge.call(dep_chapter_id, chapter_id)
    end
  end
  
  # Handle MUST-BE-BEFORE dependencies (tagged chapters depend on this chapter)
  chapter_must_come_before.each do |chapter_id, before_tags|
    before_tags.each do |tag|
      before_chapter_id = tag_definitions[tag]
      next unless before_chapter_id
      
      # chapter_id must come before before_chapter_id
      add_topological_edge.call(chapter_id, before_chapter_id)
    end
  end

  # A chapter from a source thread must never jump ahead of an earlier chapter
  # from that same source file when pragma sorting is applied.
  source_order_sequences.each do |chapter_ids|
    chapter_ids.each_cons(2) do |before_id, after_id|
      add_topological_edge.call(before_id, after_id)
    end
  end

  all_chapters_by_id.each do |before_id|
    before_act_order = chapter_act_order[before_id]
    next if before_act_order.nil?

    all_chapters_by_id.each do |after_id|
      after_act_order = chapter_act_order[after_id]
      next if after_act_order.nil?
      next unless before_act_order < after_act_order

      add_topological_edge.call(before_id, after_id)
    end
  end
  
  # Kahn's algorithm for topological sort
  queue = []
  in_degree.each do |chapter_id, degree|
    queue << chapter_id if degree == 0
  end
  
  sorted = []
  while queue.size > 0
    current = queue.shift
    sorted << current
    
    (adjacency[current] || []).each do |neighbor|
      in_degree[neighbor] -= 1
      queue << neighbor if in_degree[neighbor] == 0
    end
  end
  
  # Check if all chapters were sorted (if not, there's a cycle we missed)
  if sorted.size != all_chapters_by_id.size
    abort "*** ERROR: Topological sort failed - cycle detected in pragma dependencies"
  end
  
  sorted
end

def source_order_sequences_for(all_data, target_files)
  target_files.map do |file|
    next [] unless all_data[file]

    all_data[file][:chapters].keys.map { |local_ch_num| "#{file}:#{local_ch_num}" }
  end
end

def act_order_index_for(all_acts, target_files)
  act_order = {}

  target_files.each do |file|
    (all_acts[file] || []).each do |act_data|
      act_id = act_id_from_line(act_data[:line])
      next unless act_id
      next if act_order.key?(act_id)

      act_order[act_id] = act_order.size
    end
  end

  act_order
end

def chapter_act_order_for(all_data, all_acts, target_files)
  act_order = act_order_index_for(all_acts, target_files)
  ret = {}

  target_files.each do |file|
    next unless all_data[file]

    all_data[file][:chapters].each_key do |local_ch_num|
      act_id = chapter_act_id(local_ch_num, all_acts[file] || [])
      ret["#{file}:#{local_ch_num}"] = act_order[act_id]
    end
  end

  ret
end

def acts_by_chapter_id(all_acts, target_files)
  ret = Hash.new { |h, k| h[k] = [] }

  target_files.each do |file|
    (all_acts[file] || []).each do |act_data|
      next unless act_data[:before_chapter]

      ret["#{file}:#{act_data[:before_chapter]}"] << act_data
    end
  end

  ret
end

# Shared function to parse all chapters and Acts, and validate structure
def build_interleaved_data(all_data, all_acts, max_chapter, pragma_registry = nil)
  # Validate that Act lines are identical across all files (up to the minimum count)
  # It is acceptable for one file to have fewer Acts at the end than another
  if all_acts.values.length > 1
    first_file_acts = all_acts[$target_files[0]]
    $target_files[1..-1].each do |file|
      file_acts = all_acts[file]
      
      # Only validate Acts up to the minimum count between the two files
      min_acts = [first_file_acts.length, file_acts.length].min
      
      min_acts.times do |idx|
        if first_file_acts[idx][:line] != file_acts[idx][:line]
          first_lineno = first_file_acts[idx][:line_no] || "unknown"
          second_lineno = file_acts[idx][:line_no] || "unknown"
          abort "*** SYNTAX ERROR: Act line differs between #{$target_files[0]} (line #{first_lineno}) and #{file} (line #{second_lineno}): \n  #{$target_files[0]}: #{first_file_acts[idx][:line]}\n  #{file}: #{file_acts[idx][:line]}"
        end
      end
    end
  end

  # Build list of all chapters in "file:chapter_num" format
  all_chapters = []
  (1..max_chapter).each do |local_ch_num|
    $target_files.each do |file|
      if all_data[file][:chapters][local_ch_num]
        all_chapters << "#{file}:#{local_ch_num}"
      end
    end
  end
  
  sorted_chapters = topological_sort_chapters(
    pragma_registry ? pragma_registry[:chapter_dependencies] : {},
    pragma_registry ? pragma_registry[:chapter_must_come_before] : {},
    pragma_registry ? pragma_registry[:tag_definitions] : {},
    all_chapters,
    source_order_sequences_for(all_data, $target_files),
    chapter_act_order_for(all_data, all_acts, $target_files)
  )
  
  # Build interleaved structure with pragmas-respecting chapter order
  # Output Acts when we reach the chapter that follows the marker in any source file.
  interleaved = []
  sequential_chapter_num = 0
  act_markers_by_chapter_id = acts_by_chapter_id(all_acts, $target_files)
  seen_act_lines = Set.new

  sorted_chapters.each do |chapter_id|
    file, local_ch_num_str = chapter_id.split(':')
    local_ch_num = local_ch_num_str.to_i

    act_markers_by_chapter_id[chapter_id].each do |act_data|
      next if seen_act_lines.include?(act_data[:line])

      interleaved << { :type => :act, :line => act_data[:line] }
      seen_act_lines.add(act_data[:line])
    end
    
    sequential_chapter_num += 1
    chapter_data = all_data[file][:chapters][local_ch_num]
    source_id = extract_source_id(file)

    # Augment the chapter header with source identifier/original chapter and renumber to sequential
    augmented_text = chapter_data[:full_text].dup
    augmented_text.sub!(/^(\*\*\s*chapter\s+)(\d+)([^:\n]*:)/i) do
      "#{$1}#{sequential_chapter_num} (#{source_id} #{$2})#{$3}"
    end

    interleaved << { :type => :chapter, :text => augmented_text, :chapter_id => chapter_id, :sequential_num => sequential_chapter_num }
  end

  interleaved
end

# Validate pragma constraints in the interleaved output
# Reports each constraint and whether it was satisfied
def validate_pragma_constraints_in_output(interleaved, pragma_registry, all_data, target_files)
  # Build mapping: chapter_id => sequential_number in output
  chapter_positions = {}
  interleaved.each do |item|
    if item[:type] == :chapter && item[:chapter_id]
      chapter_positions[item[:chapter_id]] = item[:sequential_num]
    end
  end

  failures = []
  
  # Check all pragmas
  target_files.each do |file|
    all_data[file][:chapters].each do |local_ch_num, chapter_data|
      pragmas = chapter_data[:pragmas] || { :defines => nil, :depends_on => [] }
      chapter_id = "#{file}:#{local_ch_num}"
      seq_num = chapter_positions[chapter_id]
      
      next unless seq_num  # Chapter not in output
      
      # Report DEFINE-TAG pragmas
      if pragmas[:defines]
        puts "  * chapter #{seq_num}: tag '#{pragmas[:defines]}' ; defined"
      end
      
      # Check MUST-BE-AFTER constraints
      pragmas[:depends_on].each do |tag|
        dep_chapter_id = pragma_registry[:tag_definitions][tag]
        
        unless dep_chapter_id
          # Tag undefined - already reported earlier
          next
        end
        
        dep_seq_num = chapter_positions[dep_chapter_id]
        
        if dep_seq_num && dep_seq_num < seq_num
          puts "  * chapter #{seq_num}: MUST-BE-AFTER '#{tag}' - ✓ satisfied (#{tag} at chapter #{dep_seq_num})"
        else
          puts "  * chapter #{seq_num}: MUST-BE-AFTER '#{tag}' - ✗ FAILED (#{tag} not before this chapter)"
          failures << "Chapter #{seq_num} depends on '#{tag}' but it's not positioned before it"
        end
      end
      
      # Check MUST-BE-BEFORE constraints
      (pragmas[:must_come_before] || []).each do |tag|
        before_chapter_id = pragma_registry[:tag_definitions][tag]
        
        unless before_chapter_id
          # Tag undefined - already reported earlier
          next
        end
        
        before_seq_num = chapter_positions[before_chapter_id]
        
        if before_seq_num && seq_num < before_seq_num
          puts "  * chapter #{seq_num}: MUST-BE-BEFORE '#{tag}' - ✓ satisfied (#{tag} at chapter #{before_seq_num})"
        else
          puts "  * chapter #{seq_num}: MUST-BE-BEFORE '#{tag}' - ✗ FAILED (#{tag} not after this chapter)"
          failures << "Chapter #{seq_num} must come before '#{tag}' but it's not positioned before it"
        end
      end
    end
  end
  
  if failures.size > 0
    puts ""
    puts "  *** CONSTRAINT VIOLATIONS DETECTED ***"
    failures.each { |f| puts "  *** #{f}" }
    abort "Pragma constraints not satisfied in output"
  end

  # Warn about unused tags (defined but never referenced)
  if pragma_registry[:unused_tags] && !pragma_registry[:unused_tags].empty?
    puts ""
    puts "  *** WARNING: The following tags are defined but never referenced in any MUST-BE-AFTER or MUST-BE-BEFORE pragma:"
    pragma_registry[:unused_tags].each do |tag|
      chapter_id = pragma_registry[:tag_definitions][tag]
      puts "    - tag '#{tag}' defined in #{chapter_id}"
    end
  end
end

# Process underscores for italics, converting _text_ to <i>text</i>
# Validates that: italics don't have unintended underscores mid-alphanumeric
# and that italicized text is <= 40 characters
def process_italics_for_html(text)
  result = ""
  i = 0
  
  while i < text.length
    # Look for opening underscore
    if text[i] == '_'
      # Check if this is a middle underscore (between alphanumerics)
      prev_char = i > 0 ? text[i-1] : nil
      next_char = i < text.length - 1 ? text[i+1] : nil
      
      if prev_char&.match?(/[a-zA-Z0-9]/) && next_char&.match?(/[a-zA-Z0-9]/)
        # Middle underscore like in "file_1.txt" - warn but keep it
        context_start = [i - 5, 0].max
        context_end = [i + 6, text.length].min
        warn "WARNING: underscore found within alphanumerics at position #{i}: ...#{text[context_start...context_end]}"
        result += text[i]
        i += 1
        next
      end
      
      # Try to find closing underscore
      close_idx = text.index('_', i + 1)
      
      if close_idx.nil?
        # No closing underscore found - just keep the opening one
        result += text[i]
        i += 1
      else
        # Extract italicized content
        italic_content = text[i+1...close_idx]
        
        # Check length
        if italic_content.length > 40
          abort "*** SYNTAX ERROR: Italicized text is #{italic_content.length} characters (max 40 allowed), likely missing closing underscore:\n  #{italic_content[0..50]}..."
        end
        
        # Check for closing underscore surrounded by alphanumerics
        next_after_close = close_idx < text.length - 1 ? text[close_idx + 1] : nil
        if next_char&.match?(/[a-zA-Z0-9]/) && next_after_close&.match?(/[a-zA-Z0-9]/)
          warn "WARNING: closing underscore found within alphanumerics at position #{close_idx}"
        end
        
        # Convert to HTML italic tag
        result += "<i>#{CGI.escapeHTML(italic_content)}</i>"
        i = close_idx + 1
      end
    else
      result += text[i]
      i += 1
    end
  end
  
  result
end

## Helper: Remove arrows like <==, <===, <====, etc. from text
def remove_arrows(text)
  # Remove any arrows like <==, <===, <====, etc. at the start of lines or inline
  text.gsub(/<={2,}/, "")
end

def frontmatter_files(config)
  configured = config[:frontmatter] || config["frontmatter"] || config[:front_matter] || config["front_matter"]
  Array(configured).compact
end

def markdown_file?(file)
  [".md", ".markdown"].include?(File.extname(file).downcase)
end

def read_frontmatter_file(file)
  abort "*** ERROR: frontmatter file #{file} not found" unless File.exist?(file)

  File.read(file)
end

def frontmatter_text(config)
  contents = frontmatter_files(config).map { |file| read_frontmatter_file(file).strip }.reject(&:empty?)
  return "" if contents.empty?

  contents.join("\n\n") + "\n\n"
end

def markdown_file_to_html(file)
  html = `pandoc #{Shellwords.escape(file)} -t html`
  abort "*** ERROR: Failed to convert frontmatter markdown #{file} to HTML using pandoc" unless $?.success?

  html
end

def plain_text_to_html(text)
  paragraphs = text.split(/\n\s*\n/).map(&:strip).reject(&:empty?)
  paragraphs.map do |paragraph|
    escaped = CGI.escapeHTML(paragraph.gsub(/\n/, " ").strip)
    "<p>#{escaped}</p>"
  end.join("\n")
end

def frontmatter_html(config)
  html_parts = frontmatter_files(config).map do |file|
    contents = read_frontmatter_file(file)
    markdown_file?(file) ? markdown_file_to_html(file) : plain_text_to_html(contents)
  end.map(&:strip).reject(&:empty?)

  return "" if html_parts.empty?

  html_parts.join("\n") + "\n"
end

def frontmatter_html_with_page_break_markers(config)
  html_parts = frontmatter_files(config).each_with_index.map do |file, idx|
    contents = read_frontmatter_file(file)
    html = markdown_file?(file) ? markdown_file_to_html(file) : plain_text_to_html(contents)
    [html.strip, %(<p>DOCX_FRONTMATTER_PAGE_BREAK_#{idx}</p>)]
  end.flatten.reject(&:empty?)

  return "" if html_parts.empty?

  html_parts.join("\n") + "\n"
end

def config_author(config)
  config[:author] || config["author"]
end

def title_page_html(config)
  title = config[:title] || config["title"] || $title
  author = config_author(config)
  html_parts = [
    %(<section class="title-page" style="page-break-after: always;">),
    %(<h1>#{CGI.escapeHTML(title.to_s)}</h1>)
  ]
  unless author.nil? || author.to_s.strip == ""
    html_parts << %(<h2>#{CGI.escapeHTML(author.to_s)}</h2>)
  end
  html_parts << %(</section>)
  html_parts.join("\n") + "\n"
end

# Format interleaved data as plain text
def format_interleaved_as_text(interleaved, config = nil)
  output_lines = []
  frontmatter = config ? frontmatter_text(config) : ""
  output_lines << frontmatter unless frontmatter.empty?

  interleaved.each do |item|
    if item[:type] == :act
      output_lines << remove_arrows(item[:line])
      output_lines << ""
    elsif item[:type] == :chapter
      output_lines << remove_arrows(item[:text])
      output_lines << ""
    end
  end

  output_lines.join("\n")
end

# Format interleaved data as HTML
def format_interleaved_as_html(interleaved, config = nil, include_title_page = false, frontmatter_page_breaks = false)
  require 'cgi'

  html_parts = []
  html_parts << title_page_html(config) if config && include_title_page
  html_parts << (frontmatter_page_breaks ? frontmatter_html_with_page_break_markers(config) : frontmatter_html(config)) if config

  interleaved.each do |item|
    if item[:type] == :act
      # Remove leading asterisks from act line: "* Act 1: ..." -> "<h1>Act 1: ...</h1>"
      act_text = item[:line].sub(/^\*\s*/, "")
      act_text = remove_arrows(act_text)
      # Process italics in act text
      act_text = process_italics_for_html(act_text)
      html_parts << "<h1>#{act_text}</h1>"
    elsif item[:type] == :chapter
      # Parse chapter header and content
      lines = remove_arrows(item[:text]).split("\n")
      # First line is the chapter header (with ** removed)
      chapter_header = lines[0].sub(/^\*\*\s*/, "")
      # Process italics in chapter header
      chapter_header = process_italics_for_html(chapter_header)
      html_parts << "<h2>#{chapter_header}</h2>"
      
      # Remaining lines are chapter content
      content_lines = lines[1..-1] || []
      content_text = content_lines.join("\n").strip
      if content_text.length > 0
        # Split by double newlines to identify paragraphs
        paragraphs = content_text.split(/\n\s*\n/).map(&:strip).reject(&:empty?)
        paragraphs.each do |para|
          # Process italics in each paragraph and replace single newlines with spaces
          para_text = para.gsub(/\n/, " ").strip
          para_text = process_italics_for_html(para_text)
          html_parts << "<p>#{para_text}</p>"
        end
      end
    end
  end

  html_parts.join("\n")
end

def build_interleaved_chapters_for_targets(config)
  all_data = {}
  all_acts = {}
  max_chapter = 0

  $target_files.each do |file|
    data = parse_chapters_and_acts_from_file(file, config)
    all_data[file] = data
    all_acts[file] = data[:acts]
    max_chapter = [max_chapter, data[:chapters].keys.max || 0].max
  end

  if max_chapter == 0
    abort "No chapters found in any source files"
  end

  # Build pragma registry and validate
  pragma_registry = build_pragma_registry(all_data, $target_files)

  # Report validation errors
  if pragma_registry[:undefined_tags].size > 0
    puts "*** WARNING: Undefined pragma tags: #{pragma_registry[:undefined_tags].join(', ')}"
  end

  if pragma_registry[:unused_tags].size > 0
    puts "*** WARNING: Unused pragma tags: #{pragma_registry[:unused_tags].join(', ')}"
  end

  if pragma_registry[:circular_deps].size > 0
    abort "*** ERROR: Circular dependencies detected in pragmas: #{pragma_registry[:circular_deps].join(', ')}"
  end

  interleaved = build_interleaved_data(all_data, all_acts, max_chapter, pragma_registry)

  {
    :all_data => all_data,
    :all_acts => all_acts,
    :max_chapter => max_chapter,
    :pragma_registry => pragma_registry,
    :interleaved => interleaved
  }
end

def print_interleave_summary(max_chapter)
  puts "  Max chapter number: #{max_chapter}"
  puts "  Source files: #{$target_files.join(', ')}"
end

def print_pragma_output_validation(interleaved, pragma_registry, all_data)
  if pragma_registry[:chapter_dependencies].size > 0 || pragma_registry[:chapter_must_come_before].size > 0 || pragma_registry[:tag_definitions].size > 0
    puts ""
    puts "Pragma constraint verification:"
    validate_pragma_constraints_in_output(interleaved, pragma_registry, all_data, $target_files)
  end
end

desc "Interleave chapters from all source files and write to output.txt"
task :interleave_txt do
  result = build_interleaved_chapters_for_targets(config)
  all_data = result[:all_data]
  max_chapter = result[:max_chapter]
  pragma_registry = result[:pragma_registry]
  interleaved = result[:interleaved]

  # --- BOOK SPLIT FEATURE ---
  if book_split
    # Normalize book_split keys and values
    book_split = book_split.transform_keys(&:to_s)
    book_to_acts = {}
    book_split.each do |book, acts|
      book_to_acts[book] = acts.map(&:to_s)
    end

    # Gather all act names in the interleaved output (in order of appearance)
    all_act_names = interleaved.select { |item| item[:type] == :act }.map do |item|
      # Extract act name (e.g., '1', '2A', '2B', '3') from line
      line = item[:line]
      line[/^\*\s*Act\s*([\w\-]+)/i, 1] || line.gsub(/^\*\s*Act\s*/i, '').strip
    end

    # Validation: every act must be assigned to exactly one book
    act_to_books = Hash.new { |h, k| h[k] = [] }
    book_to_acts.each do |book, acts|
      acts.each { |act| act_to_books[act] << book }
    end

    # Error if any act is not assigned to a book
    missing_acts = all_act_names.uniq - act_to_books.keys
    unless missing_acts.empty?
      abort "*** ERROR: The following acts are not assigned to any book in book_split: #{missing_acts.join(', ')}"
    end

    # Error if any act is assigned to multiple books
    multi_books = act_to_books.select { |act, books| books.size > 1 }
    unless multi_books.empty?
      msg = multi_books.map { |act, books| "Act '#{act}' assigned to multiple books: #{books.join(', ')}" }.join("\n  ")
      abort "*** ERROR: The following acts are assigned to multiple books in book_split:\n  #{msg}"
    end

    # Output only a specific book if BOOK env var is set
    selected_books = if ENV['BOOK']
      [ENV['BOOK'].to_s]
    else
      book_to_acts.keys
    end

    selected_books.each do |book|
      acts_for_book = book_to_acts[book]
      # Output acts in the order listed in book_split
      filtered = []
      current_act = nil
      acts_seen = []
      interleaved.each do |item|
        if item[:type] == :act
          act_name = item[:line][/^\*\s*Act\s*([\w\-]+)/i, 1] || item[:line].gsub(/^\*\s*Act\s*/i, '').strip
          current_act = act_name
          next unless acts_for_book.include?(act_name)
          # Only output act if it's in this book
          filtered << item
          acts_seen << act_name unless acts_seen.include?(act_name)
        elsif item[:type] == :chapter
          # Only output chapters that belong to the current act for this book
          if current_act && acts_for_book.include?(current_act)
            filtered << item
          end
        end
      end
      # Error if acts appear out of order
      if acts_seen != acts_for_book
        abort "*** ERROR: Acts for book '#{book}' do not appear in the order specified in book_split.\n  Expected: #{acts_for_book.join(', ')}\n  Found:    #{acts_seen.join(', ')}"
      end
      output_text = format_interleaved_as_text(filtered, config)
      fname = book.gsub(/[^a-zA-Z0-9_\-]+/, '_') + ".txt"
      File.open(fname, "w") { |f| f.write(output_text) }
      puts "Wrote interleaved chapters to #{fname}"
    end
    print_interleave_summary(max_chapter)
    exit 0
  end
  # --- END BOOK SPLIT FEATURE ---

  output_text = format_interleaved_as_text(interleaved, config)

  File.open("output.txt", "w") do |f|
    f.write(output_text)
  end

  puts "Wrote interleaved chapters to output.txt"
  print_interleave_summary(max_chapter)

  # Validate pragma constraints in the output
  print_pragma_output_validation(interleaved, pragma_registry, all_data)
end

desc "Interleave chapters in memory, then show chapter overview for the result"
def print_interleaved_chapter_overview(config, hide_done)
  result = build_interleaved_chapters_for_targets(config)
  all_data = result[:all_data]
  max_chapter = result[:max_chapter]
  pragma_registry = result[:pragma_registry]
  interleaved = result[:interleaved]
  output_text = format_interleaved_as_text(interleaved, config)
  output_name = "interleaved"

  puts "Built interleaved chapters in memory"
  print_interleave_summary(max_chapter)
  print_pragma_output_validation(interleaved, pragma_registry, all_data)

  ret = get_chapter_hash(config, nil, [output_name], { output_name => output_text })
  print_chapter_report("#{$title} (interleaved)", config, ret, [output_name], { output_name => output_text }, :always, hide_done)
end

task :ich do
  print_interleaved_chapter_overview(config, false)
end

desc "Interleave chapters in memory, then show only incomplete chapters in the overview"
task :ichv do
  print_interleaved_chapter_overview(config, true)
end

def docx_reference_file(config)
  config[:docx_reference] || config["docx_reference"] || ".default.docx"
end

def pandoc_docx_reference_args(config)
  reference_file = docx_reference_file(config)
  return [] if reference_file.nil? || reference_file.to_s.strip == ""

  unless File.exist?(reference_file)
    warn "*** WARNING: DOCX reference file #{reference_file} not found; generating #{File.basename(reference_file)} without a reference document"
    return []
  end

  ["--reference-doc=#{reference_file}"]
end

# Helper function to convert HTML to DOCX using Pandoc
# Pandoc properly preserves heading hierarchy
def convert_html_to_docx_pandoc(html_file, docx_file, config = {})
  args = ["pandoc", html_file] + pandoc_docx_reference_args(config) + ["-o", docx_file]
  result = system(*args)
  
  unless result && File.exist?(docx_file)
    abort "*** ERROR: Failed to convert #{html_file} to DOCX using pandoc"
  end
end

def docx_xml_text_for(text)
  CGI.escapeHTML(text.to_s)
end

def center_docx_paragraph(paragraph_xml)
  if paragraph_xml.include?("<w:pPr>")
    return paragraph_xml if paragraph_xml.include?("<w:jc ")

    paragraph_xml.sub("</w:pPr>", %(<w:jc w:val="center"/></w:pPr>))
  else
    paragraph_xml.sub("<w:p>", %(<w:p><w:pPr><w:jc w:val="center"/></w:pPr>))
  end
end

def set_docx_paragraph_style(paragraph_xml, style_id)
  if paragraph_xml.include?("<w:pStyle ")
    paragraph_xml.sub(/<w:pStyle\s+w:val="[^"]*"\s*\/>/, %(<w:pStyle w:val="#{style_id}"/>))
  elsif paragraph_xml.include?("<w:pPr>")
    paragraph_xml.sub("<w:pPr>", %(<w:pPr><w:pStyle w:val="#{style_id}"/>))
  else
    paragraph_xml.sub("<w:p>", %(<w:p><w:pPr><w:pStyle w:val="#{style_id}"/></w:pPr>))
  end
end

def add_docx_page_break_after_paragraph(paragraph_xml)
  return paragraph_xml if paragraph_xml.include?(%(<w:br w:type="page"))

  paragraph_xml.sub("</w:p>", %(<w:r><w:br w:type="page"/></w:r></w:p>))
end

def docx_page_break_paragraph
  %(<w:p><w:r><w:br w:type="page"/></w:r></w:p>)
end

def postprocess_docx_title_page(docx_file, config)
  require 'zip'

  title = config[:title] || config["title"] || $title
  author = config_author(config)
  title_text = docx_xml_text_for(title)
  author_text = docx_xml_text_for(author)

  Zip::File.open(docx_file) do |zip|
    entry = zip.find_entry("word/document.xml")
    return unless entry

    xml = entry.get_input_stream.read
    title_done = false
    author_done = author.nil? || author.to_s.strip == ""

    xml = xml.gsub(/<w:p\b.*?<\/w:p>/m) do |paragraph|
      if !title_done && paragraph.include?(title_text)
        title_done = true
        paragraph = set_docx_paragraph_style(paragraph, "TitlePageTitle")
        paragraph = center_docx_paragraph(paragraph)
        paragraph = add_docx_page_break_after_paragraph(paragraph) if author_done
        paragraph
      elsif !author_done && paragraph.include?(author_text)
        author_done = true
        paragraph = set_docx_paragraph_style(paragraph, "TitlePageAuthor")
        paragraph = center_docx_paragraph(paragraph)
        add_docx_page_break_after_paragraph(paragraph)
      else
        paragraph.include?("DOCX_FRONTMATTER_PAGE_BREAK_") ? docx_page_break_paragraph : paragraph
      end
    end

    zip.get_output_stream("word/document.xml") { |f| f.write(xml) }
  end
end

desc "Interleave chapters from all source files and write to output.html"
task :interleave_html do
  require 'cgi'

  result = build_interleaved_chapters_for_targets(config)
  all_data = result[:all_data]
  max_chapter = result[:max_chapter]
  pragma_registry = result[:pragma_registry]
  interleaved = result[:interleaved]
  output_html = format_interleaved_as_html(interleaved, config)

  File.open("output.html", "w") do |f|
    f.write(output_html)
  end

  puts "Wrote interleaved chapters to output.html"
  print_interleave_summary(max_chapter)
  print_pragma_output_validation(interleaved, pragma_registry, all_data)
end

desc "Interleave chapters from all source files and write to output.docx"
task :interleave_doc do
  require 'cgi'

  result = build_interleaved_chapters_for_targets(config)
  all_data = result[:all_data]
  max_chapter = result[:max_chapter]
  pragma_registry = result[:pragma_registry]
  interleaved = result[:interleaved]
  output_html = format_interleaved_as_html(interleaved, config, true, true)

  # Write HTML to temporary file
  html_file = "output.html"
  File.open(html_file, "w") do |f|
    f.write(output_html)
  end

  puts "Wrote interleaved chapters to #{html_file}"
  
  # Convert HTML to DOCX using pandoc (preserves heading hierarchy)
  docx_file = "output.docx"
  convert_html_to_docx_pandoc(html_file, docx_file, config)
  postprocess_docx_title_page(docx_file, config)
  
  puts "Converted to #{docx_file}"
  print_interleave_summary(max_chapter)
  print_pragma_output_validation(interleaved, pragma_registry, all_data)
end

