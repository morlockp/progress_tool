    puts "========== #{infile_name}"
    count = 0
    first = true
    File.open(infile_name, "r") do |infile_h|
      
      while (line = infile_h.gets)
        if line.match(/^\*\* /)
          if first
            first = false
          else
            puts "scene = #{count}"
            count = 0
          end
          puts  line
        elsif line.match(/^\s*scene/)
          count += 1
        end
      end
    end
    puts "scene = #{count}"
  end
