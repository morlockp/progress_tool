# usage
# -----
#
# uses .rakefile.yaml which specifies
#   - target_file that we're monitoring
#   - title of the book
#   - expected word count
#  two modes:
#      - regular:         rake
#      - chapter listing: rake chapters
#
#  can also be supplied with a git hash, to apply to an earlier version
#      - regular:         rake default[047b60168aa7ee1ba2d1d9cd515ddf749ccee8f3]
#      - chapter listing: rake chapters[047b60168aa7ee1ba2d1d9cd515ddf749ccee8f3]

require 'date'
require 'yaml'

class Numeric
  # from
  #   http://pleac.sourceforge.net/pleac_ruby/numbers.html
  def commify
    self.to_s =~ /([^\.]*)(\..*)?/
    int, dec = $1.reverse, $2 ? $2 : ""
    while int.gsub!(/(,|\.|^)(\d{3})(\d)/, '\1\2,\3')
    end
    int.reverse + dec 
  end
end


## read config file#
configfile = "./.rakefile.yaml"
if FileTest.exist?(configfile)
  config  = YAML.load_file(configfile)
else
  config  = { :target_files => ["story.txt"],
              :title =>"unknown title",
              :target_words => 125000,
              :date_start => "1 Jan 1970",
              :revise_start_str => nil
            }
end

# Support both single file (:target_file) and multiple files (:target_files)
if config[:target_files]
  $target_files = config[:target_files]
elsif config[:target_file]
  $target_files = [config[:target_file]]
else
  $target_files = ["story.txt"]
end

$target_file = $target_files[0]  # for backward compatibility

title = config[:title]
target_words = config[:target_words]
# expose these to helper methods as globals so task methods can access them
$target_words = target_words
$title = title

date_start        = Date.parse(config[:date_start])

unused_file       = "unused.txt"  # where we store unused snippets of text
$words_per_page    = 250

# how big a chapter has to be before we consider that it's been started
$size_cutoff_chapter = config[:size_cuttoff_chapter] || 500

# chapter_words  - hash of chapter numbers -> words in each chapter
# chapter_titles - hash of chapter numbers -> titles
# done           - number of finished chapters
# notdone        - number of unfinished chapters
# avg            - avg wordsize of finished chapters
# std_dev        - std dev of chapter size

# Helper function to read content from target files
def get_target_content(files, git_hash = nil)
  content = ""
  files.each do |file|
    if git_hash
      content += `git show #{git_hash}:#{file}`
    else
      if File.exist?(file)
        content += File.read(file)
      else
        warn "*** warning: target file #{file} not found; skipping"
      end
    end
  end
  content
end

def get_chapter_hash(config, git_hash)

  chapter_head_tag = config[:chapter_head_tag] || "== chapter"
  
  chapter_words = {}
  chapter_arrows = {}
  chapter_titles = {}
  chapter_done = {}
  chapter_file = {}
  chapter_global_num = {}
  ii = 0
  
  $target_files.each do |file|
    if git_hash
      contents = `git show #{git_hash}:#{file}`
    else
      if File.exist?(file)
        contents = File.read(file)
      else
        warn "*** warning: target file #{file} not found; skipping in chapter analysis"
        contents = ""
      end
    end
    
    arr = contents.split(chapter_head_tag)
    arr = arr.slice(1..9999)
    arr ||= []
    
    chapters_in_this_file = Set.new
    
    arr.each do |text|
      ii += 1
      title_line = text.split("\n")[0]
      title_line.match(/ (\d+)/)
      chapter_num_str = $1

      # bug: drop the first line here
      if chapter_num_str
        chap_num = $1.to_i
      else
        chap_num = ii
      end

      raise "*** error: duplicate chapter #{chap_num} in file #{file}" if chapters_in_this_file.include?(chap_num)
      chapters_in_this_file.add(chap_num)
      
      word_count = text.split.size

      # Use a unique key combining file and chapter number to prevent overwrites
      unique_key = "#{file}:#{chap_num}"

      chapter_words[unique_key] = word_count

      chapter_arrows[unique_key] = text.match?(/<---/)

      title = title_line.split(":")[1..].join(":")
      chapter_titles[unique_key] = title

      # allow explicit override tags
      # backwards-compat: old misspelled ignore tag still respected
      force_done_tag = config[:size_cutoff_force_done] || config[:size_cuttoff_ignore_tag]
      force_done = force_done_tag && text.match?(force_done_tag)
      force_incomplete = config[:size_cutoff_force_incomplete] && text.match?(config[:size_cutoff_force_incomplete])
      if force_incomplete
        chapter_done[unique_key] = false
      elsif force_done
        chapter_done[unique_key] = true
      else
        chapter_done[unique_key] = word_count > $size_cutoff_chapter
      end
      
      chapter_file[unique_key] = file
      chapter_global_num[unique_key] = chap_num
    end
  end

  # figure out how many chapters are done
  #
  done = chapter_done.count { |k, v| v }
  done = [done, 1].max
  notdone = chapter_words.size - done

  # find avg chapter length and std dev
  #
  avg = chapter_words.select { |ch,words|  words > $size_cutoff_chapter}.sum{|ch,words| words} / done

  variance_array = chapter_words.select { |ch,words|  words > $size_cutoff_chapter}.map{|ch,words| (words - avg) }

  std_dev = variance_array.size == 0 ? 0 :   Math.sqrt(variance_array.sum { |v| v ** 2} / variance_array.size)

  return { :chapter_words  => chapter_words,
           :chapter_titles => chapter_titles,
           :chapter_arrows => chapter_arrows,
           :chapter_done   => chapter_done,
           :chapter_file   => chapter_file,
           :chapter_global_num => chapter_global_num,
           :done           => done,
           :notdone        => notdone,
           :avg            => avg,
           :std_dev        => std_dev  }
  
end

desc "Show ASCII art progress graph for all target files"
task :graph do

  def print_progress_summary(title, actual_words, target_words, words_per_page, actual_chapters, target_chapters, percent_words, percent_chapters, expansion_words)
    puts ""
    puts "  +--------------------"
    puts "  | #{title}"
    puts "  |"
    puts "  | story :    #{actual_words.commify} / #{target_words&.commify}  words ( #{sprintf('%0.2f', percent_words * 100)} % )"
    puts "  |            #{actual_words / words_per_page} / #{target_words / words_per_page}  pages"
    puts "  |            #{actual_chapters} / #{target_chapters} chapters ( #{sprintf('%0.2f', percent_chapters * 100)} % )"
    puts "  | "
    puts "  |            expansion ratio: #{sprintf('%2.2f', percent_words / percent_chapters)}"
    puts "  |            words at this ratio: #{ expansion_words.commify}"
    puts "  |            pages at this ratio: #{ (expansion_words / words_per_page).commify}"
    puts "  |"
    puts "  |            #{actual_words.commify} / #{expansion_words.commify} words at this ratio ( #{sprintf('%0.2f', (actual_words * 1.0 / expansion_words * 100))} % )"
    puts "  |            #{(actual_words / words_per_page).commify} / #{(expansion_words / words_per_page).commify} pages at this ratio"
    puts "  | "
  end

  # Print the book title and a blank line before the ASCII art graph
  config = defined?(config) ? config : YAML.load_file(".rakefile.yaml")
  puts config[:title] || config["title"]
  puts

  # Step 1: Parse all files for acts and chapters
  file_data = {}
  $target_files.each do |file|
    parsed = parse_chapters_and_acts_from_file(file, config)
    file_data[file] = parsed
  end

  # Step 2: Build global act/chapter structure
  global_acts = []
  act_to_idx = {}
  act_names = []
  $target_files.each do |file|
    acts = file_data[file][:acts]
    acts.each do |act|
      act_line = act[:line]
      # Extract only the act number (e.g., '1' from '* Act 1: before the storm')
      act_name = act_line[/^\*\s*Act\s*([\w\-]+)/i, 1] || act_line.gsub(/^\*\s*Act\s*/i, '').strip
      unless act_to_idx.key?(act_name)
        act_to_idx[act_name] = global_acts.size
        global_acts << act_line # Keep the first full act_line for display
        act_names << act_name
      end
    end
  end

  # For each act, find max number of chapters in any file for that act
  act_chapter_max = Array.new(global_acts.size, 0)
  $target_files.each do |file|
    acts = file_data[file][:acts]
    chapters = file_data[file][:chapters]
    act_chap_map = Array.new(global_acts.size) { [] }
    chapter_nums = chapters.keys.sort
    # Map act_name to its index for deduplication
    act_name_to_idx = {}
    global_acts.each_with_index do |act_line, idx|
      act_name = act_line[/^\*\s*Act\s*([\w\-]+)/i, 1] || act_line.gsub(/^\*\s*Act\s*/i, '').strip
      act_name_to_idx[act_name] = idx
    end
    acts_by_chap = acts.map { |a| a[:before_chapter] }
    acts_names = acts.map { |a| (a[:line][/^\*\s*Act\s*([\w\-]+)/i, 1] || a[:line].gsub(/^\*\s*Act\s*/i, '').strip) }
    chapter_nums.each do |chap_num|
      idx = acts_by_chap.rindex { |n| n && chap_num >= n } || 0
      act_name = acts_names[idx]
      global_idx = act_name_to_idx[act_name]
      act_chap_map[global_idx] << chap_num
    end
    act_chap_map.each_with_index do |chaps, idx|
      act_chapter_max[idx] = [act_chapter_max[idx], chaps.size].max
    end
  end


  # Step 3: Calculate act paddings for header and bars
  act_starts = [] # index in bar string where each act's vertical bar goes
  act_widths = [] # width of each act (number of chapter chars)
  act_bar_pads = Array.new(global_acts.size, 0)
  pos = 0
  global_acts.each_with_index do |act, idx|
    act_starts << pos
    act_widths << act_chapter_max[idx]
    pos += act_chapter_max[idx] + 1 # +1 for the vertical bar (except last, but we handle that below)
  end

  # Remove the last +1 for the final act (no trailing bar)
  pos -= 1
  # Also, if any padding was added to the last bar, remove it (since no bar follows)
  act_bar_pads[-1] = 0

  # Compute minimum spacing between act names
  min_spacing = 3
  act_bar_pads = Array.new(global_acts.size, 0)
  act_name_positions = [0]
  act_names.each_with_index do |name, idx|
    next if idx == 0
    prev_end = act_name_positions[idx-1] + act_names[idx-1].length
    needed = act_starts[idx] - prev_end
    if needed < min_spacing
      pad = min_spacing - needed
      act_starts[idx..-1].each_with_index { |v, j| act_starts[idx+j] += pad }
      pos += pad
      act_bar_pads[idx-1] += pad
    end
    act_name_positions << act_starts[idx]
  end

  # Step 4: Build header
  max_filename_len = $target_files.map { |f| File.basename(f).length }.max

  header = ' ' * (max_filename_len + 2) # +2 for space and leftmost bar
  act_names.each_with_index do |name, idx|
    header = header.ljust(act_name_positions[idx] + max_filename_len + 2)
    header[act_name_positions[idx] + max_filename_len + 2, name.length] = name
  end
  puts header.rstrip

  # Step 5: Build output lines

  lines = []
  $target_files.each do |file|
    parsed = file_data[file]
    acts = parsed[:acts]
    chapters = parsed[:chapters]
    act_chap_map = Array.new(global_acts.size) { [] }
    chapter_nums = chapters.keys.sort
    acts_by_chap = acts.map { |a| a[:before_chapter] }
    chapter_nums.each do |chap_num|
      idx = acts_by_chap.rindex { |n| n && chap_num >= n } || 0
      act_chap_map[idx] << chap_num
    end
    bar = '|'
    global_acts.each_with_index do |act_line, idx|
      chaps = act_chap_map[idx]
      (0...act_chapter_max[idx]).each do |i|
        if chaps[i]
          chap = chapters[chaps[i]]
          text = chap[:full_text]
          force_done_tag = config[:size_cutoff_force_done] || config[:size_cuttoff_ignore_tag]
          force_done = force_done_tag && text.match?(force_done_tag)
          force_incomplete = config[:size_cutoff_force_incomplete] && text.match?(config[:size_cutoff_force_incomplete])
          word_count = text.split.size
          is_done = if force_incomplete
            false
          elsif force_done
            true
          else
            word_count > $size_cutoff_chapter
          end
          bar << (is_done ? "=" : "-")
        else
          bar << " "
        end
      end
      # Add vertical bar unless this is the last act
      if idx < global_acts.size - 1
        bar << ' ' * act_bar_pads[idx] + '|'
      end
    end
    # Pad bar to match header length
    bar = bar.ljust(pos)
    fname = File.basename(file).ljust(max_filename_len)
    lines << "#{fname}  #{bar}"
  end

  # Step 6: Print output
  lines.each { |l| puts l.rstrip }
end
desc "create a new .rakefile.yaml"
task :init do
  yaml_file = ".rakefile.yaml"
  if FileTest.exist?(yaml_file)
    puts "*** #{yaml_file} already exists; just edit it"
  end
  File.open(yaml_file, "w") do |file|
    file.write(<<-STRING
---
:target_files:
  - ./story.txt
:title: "title goes here"
:target_words: 125000
:date_start: '#{Date.today}'
:chapter_head_tag: '** chapter'
:size_cuttoff_chapter: 600
:size_cutoff_force_done: 'AAA-chapter-complete'
# use the tag below to force a chapter to be marked incomplete even if it exceeds the cutoff
# :size_cutoff_force_incomplete: 'TAG_NAME'
STRING
              )
  end
  puts "created file ./#{yaml_file}"
end


# takes an optional git hash in case you've already committed the files and still want to run the command
#
# without git hash spec:
#   rake
#
# with git hash spec:
#   rake default[047b60168aa7ee1ba2d1d9cd515ddf749ccee8f3]
#
desc "generate stats - optionally from a git hash with `rake default[<hashID>]`"
task :default, [:git_hash] do |t, args|

  verbose = false

  # setup: figure out how to get the text of target version and previous version 
  #
  cat_str = get_target_content($target_files, args[:git_hash])

  cat_prev_str = if args[:git_hash]
                    get_target_content($target_files, "#{args[:git_hash]}^1")
                  else
                    # Get previous version from git
                    content = ""
                    $target_files.each do |file|
                      content += `git show HEAD:#{file}`
                    end
                    content
                  end



  
  # XXX maybe rewrite this function to use 'cat_str' ???
  #
  ret = get_chapter_hash(config, args[:git_hash])
  actual_chapters = ret[:done]
  target_chapters   = ret[:done] + ret[:notdone]

  
  actual_words = cat_str.split.size
  
  
  to_go_words = target_words - actual_words

  percent_words    =  actual_words * 1.0 / target_words
  percent_chapters =  actual_chapters * 1.0 / target_chapters

  # date and rate
  #
  days_since_start = [(Date.today - date_start).to_i + 1, 1].max
  write_rate       = [(actual_words / days_since_start ).to_i, 1].max
  to_go_days       = to_go_words / write_rate



  
  xxx_count_now = cat_str.scan(/XXX/).size
  yyy_count_now = cat_str.scan(/YYY/).size
  zzz_count_now = cat_str.scan(/ZZZ/).size


  xxx_count_prev = cat_prev_str.scan(/XXX/).size

  yyy_count_prev = cat_prev_str.scan(/YYY/).size
  zzz_count_prev = cat_prev_str.scan(/ZZZ/).size

  xxx_diff = xxx_count_now - xxx_count_prev
  yyy_diff = yyy_count_now - yyy_count_prev
  zzz_diff = yyy_count_now - yyy_count_prev

  xxx_diff_str = "#{xxx_diff >= 0 ? "+" : ""}#{xxx_diff}"
  yyy_diff_str = "#{yyy_diff >= 0 ? "+" : ""}#{yyy_diff}"
  zzz_diff_str = "#{yyy_diff >= 0 ? "+" : ""}#{zzz_diff}"
  


  if verbose 
    puts "cat_str = #{cat_str}"
    puts "----"
    puts "cat_prev_str = #{cat_prev_str}"
    puts "----"
    
    puts "xxx_count_now = #{xxx_count_now}"
    puts "yyy_count_now = #{yyy_count_now}"
    puts "zzz_count_now = #{zzz_count_now}"
    
    puts "xxx_count_prev = #{xxx_count_prev}"
    puts "yyy_count_prev = #{yyy_count_prev}"
    puts "zzz_count_prev = #{zzz_count_prev}"

  end
  
  # XXX rewrite this to use "cat_str" and "cat_prev_str"
  #

  # the '--text' flag to grep forces grep to consider input as text.  This
  # is useful in case the file somehow has a non ASCII character, and the git diff 
  # would  merely say "binary files match / don't match"
  # and then grep would not see any \+ or \- in the output
  # and thus report "0 words added / deleted"
  #
  # words_minus = cat_prev_str.split.size - cat_str.split.size
  # words_plus = cat_str.split.size - cat_prev_str.split.size
  # words_delta = words_plus - words_minus

  # unused_minus = File.exist?(unused_file) ? File.read(unused_file).split.size : 0
  # unused_plus = unused_minus # Adjust logic if needed
  # unused_delta = unused_plus - unused_minus

  # XXX this is wrong ; doesn't work when a hash is passed in
  words_minus      = 0
  words_plus       = 0
  $target_files.each do |file|
    words_minus += `git diff  #{args[:git_hash]} #{file}  | grep "^\-" | wc -w`.to_i
    words_plus  += `git diff  #{args[:git_hash]} #{file}  | grep "^\+" | wc -w`.to_i
  end
  words_delta      = words_plus - words_minus

  unused_minus      = `git diff  #{args[:git_hash]} #{unused_file}  | grep "^\-" | wc -w`.to_i
  unused_plus       = `git diff  #{args[:git_hash]} #{unused_file}  | grep "^\+" | wc -w`.to_i
  unused_delta      = unused_plus - unused_minus

  
  if verbose

    puts "words_minus #{words_minus}"
    puts "words_plus #{words_plus}"

  end

  # XXX this is wrong ; doesn't work when a hash is passed in
  revised_words_before = cat_prev_str.split(/\s+/).index { |word| word.match?(/^<--+/) } || 0
  revised_words = cat_str.split(/\s+/).index { |word| word.match?(/^<--+/) } || 0
  puts "revised_words = #{revised_words}"
  revised_words_delta = revised_words - revised_words_before
  
  revised_fraction = revised_words * 1.0 / actual_words
  revised_words_delta_fraction = revised_words_delta * 1.0 / actual_words

  
  if revised_words > 0
    puts "config[:revise_start_str] = #{config[:revise_start_str]}"
    revise_start_str = config[:revise_start_date] || `git log -G "<--" --follow --  story.txt | tac | grep "Date:" | head -1 | cut -d: -f2-5`
    puts "* revise_start_str = `#{revise_start_str}`"
    if revise_start_str && revise_start_str != ""
      revise_start_date = Date.parse(revise_start_str)
    else
      revise_start_date = Date.today
    end
	puts "* revise_start_date = #{revise_start_date}"
    days_since_start = (Date.today - revise_start_date).to_i
    days_since_start = 1 if days_since_start == 0
	puts "* days_since_start = #{days_since_start}"
    revise_rate      = (revised_words / days_since_start ).to_i || 1
    revise_rate      = 100 if revise_rate == 0
	puts "revise_rate = #{revise_rate.inspect}"
    to_revise_words  = actual_words - revised_words
    to_go_days       = to_revise_words / revise_rate
  end

  expansion_words = (target_words * percent_words / percent_chapters).floor
  to_go_words_expansion      = expansion_words - actual_words
  to_go_days_expansion       = to_go_words_expansion / write_rate

  


# Move print_progress_summary above :graph task
def print_progress_summary(title, actual_words, target_words, words_per_page, actual_chapters, target_chapters, percent_words, percent_chapters, expansion_words)
  puts ""
  puts "  +--------------------"
  puts "  | #{title}"
  puts "  |"
  puts "  | story :    #{actual_words.commify} / #{target_words&.commify}  words ( #{sprintf('%0.2f', percent_words * 100)} % )"
  puts "  |            #{actual_words / words_per_page} / #{target_words / words_per_page}  pages"
  puts "  |            #{actual_chapters} / #{target_chapters} chapters ( #{sprintf('%0.2f', percent_chapters * 100)} % )"
  puts "  | "
  puts "  |            expansion ratio: #{sprintf('%2.2f', percent_words / percent_chapters)}"
  puts "  |            words at this ratio: #{ expansion_words.commify}"
  puts "  |            pages at this ratio: #{ (expansion_words / words_per_page).commify}"
  puts "  |"
  puts "  |            #{actual_words.commify} / #{expansion_words.commify} words at this ratio ( #{sprintf('%0.2f', (actual_words * 1.0 / expansion_words * 100))} % )"
  puts "  |            #{(actual_words / words_per_page).commify} / #{(expansion_words / words_per_page).commify} pages at this ratio"
  puts "  | "
end
    # Print progress summary at the top
    # Reuse logic from default task
    cat_str = get_target_content($target_files)
    actual_words = cat_str.split.size
    percent_words = ($target_words && $target_words > 0) ? (actual_words * 1.0 / $target_words) : 0.0
    # For chapters, reuse logic from get_chapter_hash
    ch_hash = get_chapter_hash(config, nil)
    actual_chapters = ch_hash[:done]
    target_chapters = ch_hash[:done] + ch_hash[:notdone]
    percent_chapters = (target_chapters > 0) ? (actual_chapters * 1.0 / target_chapters) : 0.0
    expansion_words = ($target_words * percent_words / percent_chapters).floor rescue 0
    print_progress_summary($title, actual_words, $target_words, $words_per_page, actual_chapters, target_chapters, percent_words, percent_chapters, expansion_words)
  
  # draft 2 - use the '<---' flag
  if revised_words > 0
    puts "  | revision:"
    puts "  |   today's revision:  #{revised_words_delta > 0 ? "+" : ""}#{revised_words_delta.commify} words (#{revised_words_delta > 0 ? "+" : ""}#{sprintf('%0.2f',revised_words_delta_fraction * 100)} %)"
    puts "  |   days since start:  #{days_since_start}"
    puts "  |   average rate:      #{revise_rate.commify} words / day"
    puts "  |   revised:           #{revised_words.commify} / #{actual_words.commify} words ( #{sprintf('%0.2f', revised_fraction * 100)} % )"
    puts "  |   to go:             #{to_revise_words.commify} words ;  #{to_go_days.commify} days ( #{(Date.today + to_go_days).strftime('%d %b %Y')} )"
    puts "  | "    

  end 

  if ( xxx_count_now > 0 || xxx_count_prev > 0)
    puts "  | xxx:                #{xxx_count_now} (#{xxx_diff_str})"
  end
  if ( yyy_count_now > 0 || yyy_count_prev > 0)
    puts "  | yyy:                #{yyy_count_now} (#{yyy_diff_str})"
  end
  if ( zzz_count_now > 0 || zzz_count_prev > 0)
    puts "  | zzz:                #{zzz_count_now} (#{zzz_diff_str})"
  end
  
  puts "  | moved to unused:    #{words_delta > 0 ? "+" : ""}#{unused_delta.commify}"
  puts "  | "
  puts "  | today's word delta: #{words_delta > 0 ? "+" : ""}#{words_delta.commify}   (+#{words_plus.commify} -#{words_minus.commify})"
  puts "  | days since start:   #{days_since_start}"
  puts "  | average rate:       #{write_rate.commify} words / day"
  if revised_words == 0
    puts "  | to go:              #{to_go_words.commify} words ;  #{to_go_days.commify} days ( #{(Date.today + to_go_days).strftime('%d %b %Y')} )"
    puts "  | to go (expansion):  #{to_go_words_expansion.commify} words ;  #{to_go_days_expansion.commify} days ( #{(Date.today + to_go_days_expansion).strftime('%d %b %Y')} )"
  end

  puts "  +--------------------"
  puts ""



end

# Helper: build stats used by other tasks (commit message generation)
def build_basic_stats(git_hash = nil)
  cat_str = get_target_content($target_files, git_hash)
  actual_words = cat_str.split.size
  # use global $target_words (guard for nil/0)
  percent_words = ($target_words && $target_words > 0) ? (actual_words * 1.0 / $target_words) : 0.0
  { :actual_words => actual_words, :percent_words => percent_words }
end

# Build commit message reusing the same formatting as the default output
def make_commit_message(git_hash = nil)
  stats = build_basic_stats(git_hash)
  actual_words = stats[:actual_words]
  percent_words = stats[:percent_words]
  "#{$title} : #{actual_words.commify} / #{$target_words&.commify} words ( #{sprintf('%0.2f', percent_words * 100)} % )"
end

desc "git add . && git commit -m <message> -- message uses same X / Y words (Z%) logic"
task :git do
  msg = make_commit_message
  puts "Committing with message: #{msg}"
  system("git", "add", ".")

  # only commit if there are changes to commit
  changed = `git status --porcelain`
  if changed.strip == ""
    puts "No changes to commit."
  else
    system("git", "commit", "-m", msg)
  end
end


desc "change most recent commit's date to the supplied date (5pm ET). Usage: rake git_change_date['Feb 2 2026']"
task :git_change_date, [:date_str] do |t, args|
  if !args[:date_str] || args[:date_str].strip == ""
    abort "Usage: rake git_change_date['<date string>']"
  end

  begin
    parsed = Date.parse(args[:date_str])
  rescue => e
    abort "Error parsing date: #{e}"
  end

  # set time to 5pm Eastern Time (offset -05:00). If DST handling is required,
  # consider using the 'tzinfo' gem to compute the correct offset for the date.
  ts = Time.new(parsed.year, parsed.month, parsed.day, 17, 0, 0, "-05:00")
  date_arg = ts.strftime("%Y-%m-%d %H:%M:%S %z")

  puts "Amending most recent commit with date: #{date_arg}"

  unless system("git", "commit", "--amend", "--date", date_arg, "--no-edit")
    abort "git commit --amend --date failed"
  end

  env = { "GIT_COMMITTER_DATE" => date_arg }
  unless system(env, "git", "commit", "--amend", "--no-edit")
    abort "GIT_COMMITTER_DATE git commit --amend failed"
  end
end


desc "alias for :chapters"
task :ch, [:git_hash] do |t, args|
  Rake::Task[:chapters].invoke(args.values)
end

desc "generate verbose stats about chapters"
task :chapters, [:git_hash] do |t, args|
  puts "args = #{args.inspect}"
  ret           = get_chapter_hash(config, args[:git_hash])

  done           = ret[:done]
  notdone        = ret[:notdone]
  avg            = ret[:avg]
  chapter_words  = ret[:chapter_words]
  chapter_titles = ret[:chapter_titles]
  std_dev        = ret[:std_dev]
  arrows         = ret[:chapter_arrows]
  chapter_done   = ret[:chapter_done]
  chapter_file   = ret[:chapter_file]
  chapter_global_num = ret[:chapter_global_num]

  puts ""
  puts "  +--------------------"
  puts "  | #{title}"
  puts "  | "
  puts "  |  ch                                             words      stddevs"
  puts "  |  ---------------------------------------------------------------"
  
  $target_files.each do |file|
    puts "  | #{file}"
    
    # Parse acts for this file to track act boundaries
    file_data = parse_chapters_and_acts_from_file(file, config)
    acts_by_chapter = {}
    file_data[:acts].each do |act_info|
      before_ch = act_info[:before_chapter]
      act_line = act_info[:line]
      acts_by_chapter[before_ch] = act_line
    end
    
    last_act = nil
    chapter_words.each_pair do |key, words|
      next unless chapter_file[key] == file
      
      ch_num = chapter_global_num[key]
      
      # Check if there's an act transition at this chapter
      if acts_by_chapter[ch_num]
        current_act = acts_by_chapter[ch_num]
        # Extract act name (e.g., "Act 2-A" from "* Act 2-A")
        if current_act =~ /\* (Act .+)/
          current_act_name = $1
        else
          current_act_name = current_act
        end
        
        # Print separator if act changed and it's not the first act or it's transitioning from Act 1
        if last_act && current_act_name != last_act && current_act_name != "Act 1"
          puts "  | --- #{current_act_name}"
        end
        last_act = current_act_name
      end
      
      sigma = std_dev == 0.0 ? 0 : ((words - avg).abs / std_dev).floor
      ch_done  = chapter_done[key] ? "✓" : " " 
      puts "  | #{sprintf('%3i', ch_num) }  #{ch_done} #{sprintf('%-38s', chapter_titles[key][0...38])} #{sprintf('%6s',words.commify)}    #{ sprintf('%5s',(words > avg ? "+":"-") * sigma)}     #{arrows[key] ? "<--" : ""}"
    end
    puts "  | ----------"
  end

  
  puts "  |\n"
  puts "  |\n"
  puts "  | * #{done} chapters done, avg words = #{avg.commify}"
  puts "  | * stddev = #{std_dev.floor.commify}"
  puts "  | * #{notdone} chapters not done"
  puts "  | * target words @ this rate = #{ ((chapter_words.size * avg) ).commify}"
  puts "  | * target pages @ this rate = #{ ((chapter_words.size * avg) / 250).commify}"
  puts "  +--------------------"
  puts ""
end

