    puts ""
    puts "Pragma constraint verification:"
    validate_pragma_constraints_in_output(interleaved, pragma_registry, all_data, $target_files)
  end
end

# Helper function to convert HTML to DOCX using LibreOffice
# Uses two-step conversion: HTML → ODT → DOCX for better compatibility
def convert_html_to_docx(html_file, docx_file)
  output_dir = File.dirname(docx_file) == '' ? '.' : File.dirname(docx_file)
  
  # Step 1: Convert HTML to ODT
  odt_file = File.join(output_dir, File.basename(html_file, '.*') + '.odt')
  cmd_html_to_odt = "libreoffice --headless --convert-to odt #{html_file} --outdir #{output_dir}"
  result = system(cmd_html_to_odt)
  
  unless result && File.exist?(odt_file)
    abort "*** ERROR: Failed to convert #{html_file} to ODT using LibreOffice"
  end
  
  # Step 2: Convert ODT to DOCX
  cmd_odt_to_docx = "libreoffice --headless --convert-to docx #{odt_file} --outdir #{output_dir}"
  result = system(cmd_odt_to_docx)
  
  unless result && File.exist?(odt_file.gsub(/\.odt$/, '.docx'))
    abort "*** ERROR: Failed to convert #{odt_file} to DOCX using LibreOffice"
  end
  
  # Rename if output name differs
  actual_docx = odt_file.gsub(/\.odt$/, '.docx')
  if actual_docx != docx_file
    File.rename(actual_docx, docx_file) rescue nil
  end
  
  # Clean up temporary ODT file
  File.delete(odt_file) if File.exist?(odt_file)
end

desc "Interleave chapters from all source files and write to output.docx"
task :interleave_doc do
  require 'cgi'
  
  all_data = {}
  all_acts = {}
  max_chapter = 0

  $target_files.each do |file|
    data = parse_chapters_and_acts_from_file(file, config)
    all_data[file] = data
    all_acts[file] = data[:acts]
    max_chapter = [max_chapter, data[:chapters].keys.max || 0].max
  end

  if max_chapter == 0
    abort "No chapters found in any source files"
  end

  # Build pragma registry and validate
  pragma_registry = build_pragma_registry(all_data, $target_files)
  
  # Report validation errors
  if pragma_registry[:undefined_tags].size > 0
    puts "*** WARNING: Undefined pragma tags: #{pragma_registry[:undefined_tags].join(', ')}"
  end
  
  if pragma_registry[:unused_tags].size > 0
    puts "*** WARNING: Unused pragma tags: #{pragma_registry[:unused_tags].join(', ')}"
  end
  
  if pragma_registry[:circular_deps].size > 0
    abort "*** ERROR: Circular dependencies detected in pragmas: #{pragma_registry[:circular_deps].join(', ')}"
  end

  interleaved = build_interleaved_data(all_data, all_acts, max_chapter, pragma_registry)
  output_html = format_interleaved_as_html(interleaved)

  # Write HTML to temporary file
  html_file = "output.html"
  File.open(html_file, "w") do |f|
    f.write(output_html)
  end

  puts "Wrote interleaved chapters to #{html_file}"
  
  # Convert HTML to DOCX using pandoc (preserves heading hierarchy)
  docx_file = "output.docx"
  convert_html_to_docx_pandoc(html_file, docx_file)
  
  puts "Converted to #{docx_file}"
  puts "  Max chapter number: #{max_chapter}"
  puts "  Source files: #{$target_files.join(', ')}"
  
  # Validate pragma constraints in the output
  if pragma_registry[:chapter_dependencies].size > 0 || pragma_registry[:chapter_must_come_before].size > 0 || pragma_registry[:tag_definitions].size > 0
    puts ""
    puts "Pragma constraint verification:"
    validate_pragma_constraints_in_output(interleaved, pragma_registry, all_data, $target_files)
  end
end

