          <w:szCs w:val="46"/>
        </w:rPr>
      </w:style>
      <w:style w:type="paragraph" w:styleId="TitlePageAuthor">
        <w:name w:val="Title Page Author"/>
        <w:basedOn w:val="Normal"/>
